{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/averyemeyer/molopt_testing/agent_knowledge/schema.json",
  "title": "LIDDIA MolOpt Benchmark Knowledge",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_from_repository_date",
    "purpose",
    "benchmark_context",
    "objective_profiles",
    "algorithm_profiles",
    "runtime_model",
    "agent_rules"
  ],
  "properties": {
    "schema_version": {"type": "string"},
    "generated_from_repository_date": {"type": "string", "format": "date"},
    "purpose": {"type": "string"},
    "benchmark_context": {"type": "object"},
    "objective_profiles": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/objectiveProfile"}
    },
    "algorithm_profiles": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "role", "observed_generation_seconds_per_molecule"],
        "properties": {
          "id": {"type": "string"},
          "role": {"type": "string"},
          "observed_generation_seconds_per_molecule": {
            "type": "number",
            "minimum": 0
          }
        }
      }
    },
    "runtime_model": {"type": "object"},
    "agent_rules": {"type": "array", "items": {"type": "string"}}
  },
  "$defs": {
    "direction": {"enum": ["higher", "lower", "target_range"]},
    "objectiveProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "applies_to",
        "family",
        "evaluator_output",
        "molopt_score",
        "standalone_policy",
        "routing",
        "evidence",
        "caveats"
      ],
      "properties": {
        "id": {"type": "string"},
        "applies_to": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string"}
        },
        "family": {
          "enum": [
            "bounded_desirability",
            "transformed_desirability",
            "target_range_property",
            "transformed_safety"
          ]
        },
        "evaluator_output": {
          "type": "object",
          "additionalProperties": false,
          "required": ["meaning", "better_direction", "typical_range"],
          "properties": {
            "meaning": {"type": "string"},
            "better_direction": {"$ref": "#/$defs/direction"},
            "typical_range": {
              "oneOf": [
                {"type": "null"},
                {
                  "type": "array",
                  "prefixItems": [{"type": "number"}, {"type": "number"}],
                  "minItems": 2,
                  "maxItems": 2
                }
              ]
            }
          }
        },
        "molopt_score": {
          "type": "object",
          "additionalProperties": false,
          "required": ["transform", "better_direction"],
          "properties": {
            "transform": {"type": "string"},
            "better_direction": {"enum": ["higher"]}
          }
        },
        "standalone_policy": {
          "enum": ["allowed", "allowed_with_caveats", "avoid_standalone"]
        },
        "routing": {
          "type": "object",
          "additionalProperties": false,
          "required": ["preferred_algorithms", "baseline_algorithm", "guidance"],
          "properties": {
            "preferred_algorithms": {
              "type": "array",
              "items": {"type": "string"}
            },
            "baseline_algorithm": {"type": "string"},
            "guidance": {"type": "string"}
          }
        },
        "endpoint_observations": {"type": "object"},
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/evidence"}
        },
        "caveats": {"type": "array", "items": {"type": "string"}}
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "benchmark_id",
        "strength",
        "calls_per_run",
        "seeds",
        "algorithms_compared",
        "primary_metric",
        "observed_ranking",
        "key_values",
        "source_tables"
      ],
      "properties": {
        "benchmark_id": {"type": "string"},
        "strength": {
          "enum": ["strong_internal", "preliminary", "behavior_only"]
        },
        "calls_per_run": {"type": "integer", "minimum": 1},
        "seeds": {"type": "integer", "minimum": 1},
        "algorithms_compared": {
          "type": "array",
          "items": {"type": "string"}
        },
        "primary_metric": {"type": "string"},
        "observed_ranking": {
          "type": "array",
          "items": {"type": "string"}
        },
        "key_values": {
          "type": "object",
          "additionalProperties": {"type": "number"}
        },
        "source_tables": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string"}
        }
      }
    }
  }
}
